# Google Gemini API Key
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# URL du backend Ada
# Local (Electron) :
VITE_BACKEND_URL=http://localhost:8000

# Remote (VPS — pour accès depuis téléphone) :
# VITE_BACKEND_URL=https://ada.ton-vps.com

# Pour tester en remote rapide avec ngrok :
# VITE_BACKEND_URL=https://xxxx.ngrok-free.app

# Token d'authentification pour les endpoints HTTP du backend Ada
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Doit être identique dans .env (backend) et .env.local (frontend)
ADA_API_TOKEN=your_token_here
VITE_ADA_API_TOKEN=your_token_here
