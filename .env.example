# ═══════════════════════════════════════════════════════════════════════════════
# CORE — Requis au démarrage
# ═══════════════════════════════════════════════════════════════════════════════

# Google Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Token d'authentification Ada (générer: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
ADA_API_TOKEN=your_token_here
VITE_ADA_API_TOKEN=your_token_here

# URL du backend Ada
VITE_BACKEND_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE (Gmail + Calendar + Drive + Sheets + Docs + Maps + YouTube)
# ═══════════════════════════════════════════════════════════════════════════════

# OAuth2 — placer le fichier JSON dans backend/google_credentials.json
# Télécharger depuis Google Cloud Console > APIs & Services > Credentials
# Le token sera généré automatiquement au premier lancement

# Google Maps
GOOGLE_MAPS_API_KEY=

# YouTube Data API v3
YOUTUBE_API_KEY=

# ID du Google Sheet pour le budget perso
BUDGET_SHEET_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# COMMUNICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Slack — https://api.slack.com/apps > Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Telegram — https://t.me/BotFather > /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=  # Ton chat ID perso (obtenir via @userinfobot)

# Seuil texte/vocal (caractères) — réponses > seuil → note vocale OGG
TEXT_VOICE_THRESHOLD=500

# WhatsApp via Evolution API — https://doc.evolution-api.com
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=ada
WHATSAPP_DEFAULT_NUMBER=  # Format: 33612345678

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTIVITÉ
# ═══════════════════════════════════════════════════════════════════════════════

# Notion — https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# Linear — https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...  # ou sk_test_ pour les tests

# Qonto — https://app.qonto.com/settings/api
QONTO_LOGIN=               # Format: prenom.nom-XXXX
QONTO_SECRET_KEY=
QONTO_ORGANIZATION_SLUG=   # Identifiant de ton organisation Qonto

# ═══════════════════════════════════════════════════════════════════════════════
# DEV & INFRA
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase — https://app.supabase.com > Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (pas la anon key)

# Vercel — https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=  # Optionnel — pour les comptes Team

# GitHub — https://github.com/settings/tokens (scope: repo, read:user)
GITHUB_TOKEN=Github_pat_11BKMFCLY0BER2Wavfzxz2_CMR5fi8hTAKr4DQGiMJ8EIm94Y1viTgUQo7NBx1DblFN3O57Z64lrqizjal
GITHUB_DEFAULT_REPO=16ze/jarvis  # Repo par défaut

# Docker — pas de config requise (socket local /var/run/docker.sock)

# Navigateur visible en développement (false = visible si DISPLAY disponible, true = headless)
BROWSER_HEADLESS=true

# ═══════════════════════════════════════════════════════════════════════════════
# SMART HOME & PERSO
# ═══════════════════════════════════════════════════════════════════════════════

# Chromecast — nom exact du Chromecast (laisser vide pour prendre le premier trouvé)
CHROMECAST_NAME=

# Home Assistant — Settings > System > Users > Long-lived token
HOMEASSISTANT_URL=http://192.168.1.100:8123
HOMEASSISTANT_TOKEN=eyJ...

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_USERNAME=  # Ton username Spotify

# Apple Health — exporter depuis l'app Health > Profil > Exporter les données
APPLE_HEALTH_EXPORT_PATH=/Users/bryandev/Downloads/apple_health_export

# ═══════════════════════════════════════════════════════════════════════════════
# CRÉATION & MÉDIAS
# ═══════════════════════════════════════════════════════════════════════════════

# Canva — https://www.canva.com/developers
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_ACCESS_TOKEN=  # OAuth token après autorisation

# Figma — https://www.figma.com/settings > Personal access tokens
FIGMA_ACCESS_TOKEN=figd_...

# ElevenLabs — https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=  # ID de la voix par défaut (ex: voix custom Jarvis)

# Replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
